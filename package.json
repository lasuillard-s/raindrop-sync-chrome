{
	"name": "raindrop-sync-chrome",
	"version": "0.6.1",
	"author": {
		"name": "Yuchan Lee",
		"url": "https://github.com/lasuillard",
		"email": "lasuillard@gmail.com"
	},
	"homepage": "https://github.com/lasuillard-s/raindrop-sync-chrome",
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"build:watch": "vite build --watch",
		"fmt": "prettier --write .",
		"fmt:check": "prettier --check .",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"check": "svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest --run",
		"test:watch": "vitest --silent --watch --ui",
		"e2e": "playwright test",
		"e2e:watch": "playwright test --ui",
		"e2e-docker": "./e2e/playwright-docker.sh test",
		"e2e-docker:watch": "./e2e/playwright-docker.sh --ui --ui-host \"$([ -n \"$$CONTAINER\" ] && echo '0.0.0.0' || echo '127.0.0.1')\" --ui-port 8888"
	},
	"type": "module",
	"dependencies": {},
	"devDependencies": {
		"@codecov/vite-plugin": "1.9.1",
		"@crxjs/vite-plugin": "2.4.0",
		"@eslint/eslintrc": "3.3.5",
		"@eslint/js": "10.0.1",
		"@faker-js/faker": "10.4.0",
		"@floating-ui/dom": "1.7.6",
		"@lasuillard/raindrop-client": "0.7.6",
		"@playwright/test": "1.59.1",
		"@sveltejs/vite-plugin-svelte": "7.0.0",
		"@tailwindcss/postcss": "4.2.2",
		"@tailwindcss/vite": "4.2.2",
		"@testing-library/svelte": "5.3.1",
		"@testing-library/user-event": "14.6.1",
		"@tsconfig/svelte": "5.0.8",
		"@types/chrome": "0.1.39",
		"@types/node": "25.5.2",
		"@types/sinon-chrome": "2.2.16",
		"@vitest/coverage-v8": "4.1.2",
		"@vitest/ui": "4.1.2",
		"axios": "1.14.0",
		"concurrently": "9.2.1",
		"date-fns": "4.1.0",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-jsdoc": "62.9.0",
		"eslint-plugin-svelte": "3.17.0",
		"eslint": "10.2.0",
		"flowbite-svelte-icons": "3.1.0",
		"flowbite-svelte": "1.33.0",
		"flowbite": "4.0.1",
		"globals": "17.4.0",
		"happy-dom": "20.8.9",
		"postcss": "8.5.8",
		"prettier-plugin-svelte": "3.5.1",
		"prettier-plugin-tailwindcss": "0.7.2",
		"prettier": "3.8.1",
		"svelte-check": "4.4.6",
		"svelte": "5.55.1",
		"tailwind-merge": "3.5.0",
		"tailwindcss": "4.2.2",
		"tslib": "2.8.1",
		"typescript-eslint": "8.58.0",
		"typescript": "6.0.2",
		"vite-plugin-node-polyfills": "0.26.0",
		"vite-plugin-zip-pack": "1.2.4",
		"vite": "8.0.3",
		"vitest": "4.1.2",
		"wait-on": "9.0.4",
		"zod": "4.3.6"
	}
}
