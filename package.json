{
	"name": "raindrop-sync-chrome",
	"version": "0.6.1",
	"author": {
		"name": "Yuchan Lee",
		"url": "https://github.com/lasuillard",
		"email": "lasuillard@gmail.com"
	},
	"homepage": "https://github.com/lasuillard-s/raindrop-sync-chrome",
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"build:watch": "vite build --watch",
		"check": "svelte-check --tsconfig ./tsconfig.json",
		"fmt": "prettier --list-different --write .",
		"fmt:check": "prettier --list-different .",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"typecheck": "tsc --noEmit",
		"test": "vitest --run",
		"test:watch": "vitest --silent --watch --ui",
		"e2e": "playwright test",
		"e2e:watch": "playwright test --ui",
		"e2e-docker": "./e2e/playwright-docker.sh test",
		"e2e-docker:watch": "./e2e/playwright-docker.sh --ui --ui-host \"$([ -n \"$$CONTAINER\" ] && echo '0.0.0.0' || echo '127.0.0.1')\" --ui-port 8888"
	},
	"type": "module",
	"dependencies": {},
	"devDependencies": {
		"@codecov/vite-plugin": "^1.9.0",
		"@crxjs/vite-plugin": "2.3.0",
		"@eslint/eslintrc": "^3.3.0",
		"@eslint/js": "^9.39.1",
		"@faker-js/faker": "^10.2.0",
		"@floating-ui/dom": "^1.7.0",
		"@lasuillard/raindrop-client": "^0.7.1",
		"@playwright/test": "^1.58.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@tailwindcss/postcss": "^4.1.8",
		"@tailwindcss/vite": "^4.1.8",
		"@testing-library/svelte": "^5.3.1",
		"@testing-library/user-event": "^14.6.1",
		"@tsconfig/svelte": "^5.0.2",
		"@types/chrome": "^0.1.1",
		"@types/node": "^25.1.0",
		"@types/sinon-chrome": "^2.2.15",
		"@vitest/coverage-v8": "^4.0.14",
		"@vitest/ui": "^4.0.14",
		"axios": "^1.13.5",
		"concurrently": "^9.2.0",
		"date-fns": "^4.1.0",
		"eslint-config-prettier": "^10.1.1",
		"eslint-plugin-jsdoc": "^62.5.0",
		"eslint-plugin-svelte": "^3.14.0",
		"eslint": "^9.39.1",
		"flowbite-svelte-icons": "^3.1.0",
		"flowbite-svelte": "^1.31.0",
		"flowbite": "^4.0.1",
		"globals": "^17.3.0",
		"happy-dom": "^20.4.0",
		"postcss": "^8.5.1",
		"prettier-plugin-svelte": "^3.4.0",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"prettier": "3.8.1",
		"svelte-check": "^4.3.0",
		"svelte": "^5.53.5",
		"tailwind-merge": "^3.4.0",
		"tailwindcss": "^4.1.8",
		"tslib": "^2.7.0",
		"typescript-eslint": "^8.54.0",
		"typescript": "^5.9.2",
		"vite-plugin-node-polyfills": "^0.25.0",
		"vite-plugin-zip-pack": "^1.2.4",
		"vite": "^6.4.1",
		"vitest": "^4.0.14",
		"wait-on": "^9.0.3",
		"zod": "^4.3.6"
	}
}
